<Window x:Class="WpfApp1.BaoCaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Báo Cáo Định Kỳ Tháng" Height="750" Width="1050"
        WindowStartupLocation="CenterScreen" Background="#FAF8FF">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F3F9"/>
            <Setter Property="Foreground" Value="#191B23"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E1E2ED"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBEFFF"/>
                    <Setter Property="Foreground" Value="#004AC6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E1E2ED" BorderThickness="1" CornerRadius="12" Padding="20,16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Chọn Tháng" FontSize="11" FontWeight="Bold" Foreground="#737686" Margin="2,0,0,4"/>
                        <ComboBox x:Name="cbThang" Width="110" Height="36" VerticalContentAlignment="Center" Padding="10,0">
                            <ComboBoxItem Content="Tháng 1"/>
                            <ComboBoxItem Content="Tháng 2"/>
                            <ComboBoxItem Content="Tháng 3"/>
                            <ComboBoxItem Content="Tháng 4"/>
                            <ComboBoxItem Content="Tháng 5"/>
                            <ComboBoxItem Content="Tháng 6"/>
                            <ComboBoxItem Content="Tháng 7"/>
                            <ComboBoxItem Content="Tháng 8"/>
                            <ComboBoxItem Content="Tháng 9"/>
                            <ComboBoxItem Content="Tháng 10" IsSelected="True"/>
                            <ComboBoxItem Content="Tháng 11"/>
                            <ComboBoxItem Content="Tháng 12"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Chọn Năm" FontSize="11" FontWeight="Bold" Foreground="#737686" Margin="2,0,0,4"/>
                        <ComboBox x:Name="cbNam" Width="90" Height="36" VerticalContentAlignment="Center" Padding="10,0">
                            <ComboBoxItem Content="2024"/>
                            <ComboBoxItem Content="2025"/>
                            <ComboBoxItem Content="2026" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="Hệ thống tự động tổng hợp số liệu hoạt động kinh doanh, lượt xe sửa chữa và doanh thu của toàn bộ Gara." 
                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,12,0,0" Foreground="#737686" TextWrapping="Wrap" FontSize="13"/>

                <Button x:Name="BtnXemBaoCao" Grid.Column="2" Click="BtnXemBaoCao_Click"
                        Height="38" Width="140" Background="#004AC6" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartBar" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Xem báo cáo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">

            <Border Background="#F0FDF4" BorderBrush="#DCFCE7" BorderThickness="1" Margin="0,0,12,0" Padding="20,16" CornerRadius="12">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Tổng Doanh Thu" FontSize="13" Foreground="#166534" FontWeight="Medium"/>
                        <TextBlock Text="{Binding DoanhThu, StringFormat={}{0:N0} VND}" FontSize="24" FontWeight="Bold" Foreground="#15803D" Margin="0,8,0,0"/>
                        <TextBlock Text="▲ +12.5% so với tháng trước" FontSize="11" Foreground="#166534" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <materialDesign:PackIcon Kind="CurrencyUsd" HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Foreground="#15803D" Opacity="0.15"/>
                </Grid>
            </Border>

            <Border Background="#EFF6FF" BorderBrush="#DBEAFE" BorderThickness="1" Margin="6,0,6,0" Padding="20,16" CornerRadius="12">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Tổng Lượt Sửa Chữa" FontSize="13" Foreground="#1E40AF" FontWeight="Medium"/>
                        <TextBlock Text="{Binding LuotSua}" FontSize="24" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,8,0,0"/>
                        <TextBlock Text="Đạt chỉ tiêu vận hành ổn định" FontSize="11" Foreground="#1E40AF" Opacity="0.8" Margin="0,4,0,0"/>
                    </StackPanel>
                    <materialDesign:PackIcon Kind="Wrench" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" Foreground="#1D4ED8" Opacity="0.15"/>
                </Grid>
            </Border>

            <Border Background="#FFF7ED" BorderBrush="#FFEDD5" BorderThickness="1" Margin="12,0,0,0" Padding="20,16" CornerRadius="12">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Khách Hàng Mới" FontSize="13" Foreground="#9A3412" FontWeight="Medium"/>
                        <TextBlock Text="{Binding KhachHang}" FontSize="24" FontWeight="Bold" Foreground="#C2410C" Margin="0,8,0,0"/>
                        <TextBlock Text="Chỉ số tin tưởng hệ thống cao" FontSize="11" Foreground="#9A3412" Opacity="0.8" Margin="0,4,0,0"/>
                    </StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroup" HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Foreground="#C2410C" Opacity="0.15"/>
                </Grid>
            </Border>

        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E1E2ED" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock Text="📊 Biểu Đồ Thống Kê Hoạt Động" DockPanel.Dock="Top" FontSize="14" FontWeight="Bold" Foreground="#191B23" Margin="0,0,0,16"/>

                    <lvc:CartesianChart LegendLocation="Bottom">
                        <lvc:CartesianChart.Series>
                            <lvc:ColumnSeries Title="Doanh thu" Values="{Binding DoanhThuNgay}" Fill="#004AC6"/>
                            <lvc:ColumnSeries Title="Lượt sửa" Values="{Binding SoLuotSua}" Fill="#B4C5FF"/>
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="{Binding Days}" Title="Ngày trong tháng"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Giá trị (VND / Lượt)"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#E1E2ED" BorderThickness="1" CornerRadius="12" Padding="0" Margin="12,0,0,0" ClipToBounds="True">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Background="#F8FAFC" Height="46">
                        <TextBlock Text="📋 Danh Sách Doanh Thu Chi Tiết" FontSize="14" FontWeight="Bold" Foreground="#191B23" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <DataGrid ItemsSource="{Binding BaoCaoChiTiet}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày nhận" Binding="{Binding Date}" Width="1.2*"/>
                            <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding TenKH}" Width="2*"/>
                            <DataGridTextColumn Header="Dịch Vụ Thực Hiện" Binding="{Binding DVu}" Width="2*"/>

                            <DataGridTextColumn Header="Tổng Thanh Toán" Binding="{Binding TongTien, StringFormat={}{0:N0}}" Width="1.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#004AC6"/>
                                        <Setter Property="Margin" Value="0,0,16,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>