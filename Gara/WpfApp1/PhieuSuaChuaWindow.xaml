<Window x:Class="WpfApp1.PhieuSuaChuaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Phiếu sửa chữa" Height="650" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PHIẾU SỬA CHỮA" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0 -->

            <TextBlock Text="Biển số:" Grid.Row="0" Grid.Column="0" Margin="20,5,5,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="txtBienSo" Grid.Row="0" Grid.Column="1" Margin="5" Padding="4"/>

            <TextBlock Text="Ngày sửa chữa:" Grid.Row="0" Grid.Column="2" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <DatePicker x:Name="dpNgayTiepNhan" Grid.Row="0" Grid.Column="3" Margin="5" Padding="4"/>
           
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0 -->
            <DataGrid x:Name="dgvChiTiet" Grid.Row="0" AutoGenerateColumns="False" CanUserAddRows="True" 
                  CellEditEnding="dgvChiTiet_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nội dung" Binding="{Binding Content}" Width="2*"/>

                    <DataGridComboBoxColumn Header="Vật tư phụ tùng" x:Name="colVatTu" 
                                        SelectedValueBinding="{Binding PartId}" 
                                        DisplayMemberPath="PartName" SelectedValuePath="Id" Width="2*"/>

                    <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="*"/>

                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice}" IsReadOnly="True" Width="*"/>

                    <DataGridComboBoxColumn Header="Loại tiền công" x:Name="colTienCong"
                                        SelectedValueBinding="{Binding LaborId}"
                                        DisplayMemberPath="LaborName" SelectedValuePath="Id" Width="2*"/>

                    <DataGridTextColumn Header="Tiền công" Binding="{Binding LaborFee}" IsReadOnly="True" Width="*"/>

                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotal}" IsReadOnly="True" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <TextBlock Text="Tổng tiền: " VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                <TextBlock x:Name="txtTotalAmount" Text="0" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Margin="0,0,20,0" Foreground="Red"/>
                <Button Content="Lưu Phiếu" Width="100" Height="35" Click="btnLuu_Click"/>
            </StackPanel>


        </Grid>


        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnLuu" Content="Lưu" Width="100" Height="35" Margin="10" Click="btnLuu_Click"/>
            <Button x:Name="btnDong" Content="Đóng" Width="100" Height="35" Margin="10" Click="btnDong_Click"/>
        </StackPanel>
    </Grid>
</Window>
