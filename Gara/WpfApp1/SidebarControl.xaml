<UserControl x:Class="WpfApp1.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:WpfApp1"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource SidebarBgColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,32,24,40">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" Background="#2563EB" CornerRadius="8" Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="Garage" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HỆ THỐNG QUẢN LÝ" FontSize="13" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="GARA Ô TÔ" FontSize="14" FontWeight="Black" Foreground="#2563EB"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="PHẦN MỀM ĐIỀU HÀNH CHUYÊN NGHIỆP" FontSize="9" Foreground="#757681" Margin="0,6,0,0" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <RadioButton Content="Tiếp Nhận Xe (BM1)" Style="{StaticResource NavMenuButton}" Tag="FileDocumentOutline"/>
            <RadioButton Content="Phiếu Sửa Chữa (BM2)" Style="{StaticResource NavMenuButton}" Tag="WrenchOutline" IsChecked="True"/>
            <RadioButton Content="Tra Cứu Xe (BM3)" Style="{StaticResource NavMenuButton}" Tag="Magnify"/>
            <RadioButton Content="Phiếu Thu Tiền (BM4)" Style="{StaticResource NavMenuButton}" Tag="Cash"/>
            <RadioButton Content="Báo Cáo Tháng (BM5)" Style="{StaticResource NavMenuButton}" Tag="ChartBar"/>
            <RadioButton Content="Thay Đổi Quy Định (QĐ6)" Style="{StaticResource NavMenuButton}" Tag="CogOutline"/>
        </StackPanel>

        
    </Grid>
</UserControl>
