<UserControl x:Class="WpfApp1.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="260">
    <Grid Width="260" Background="{StaticResource SidebarBgColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="24,32,24,40">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40"
                        Background="{StaticResource PrimaryColor}"
                        CornerRadius="8" Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="Garage" Foreground="White"
                                             Width="24" Height="24"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HỆ THỐNG QUẢN LÝ" FontSize="13" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="GARA Ô TÔ" FontSize="14" FontWeight="Black"
                               Foreground="{StaticResource PrimaryColor}"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="PHẦN MỀM ĐIỀU HÀNH CHUYÊN NGHIỆP"
                       FontSize="9" Foreground="#757681" Margin="0,6,0,0" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <RadioButton x:Name="Bm1Button" Content="Tiếp Nhận Xe"
                         Style="{StaticResource NavMenuButton}" Tag="FileDocumentOutline"
                         CommandParameter="BM1" Click="NavigationButton_Click"/>
            <RadioButton x:Name="Bm2Button" Content="Phiếu Sửa Chữa"
                         Style="{StaticResource NavMenuButton}" Tag="WrenchOutline"
                         CommandParameter="BM2" Click="NavigationButton_Click"/>
            <RadioButton x:Name="Bm3Button" Content="Tra Cứu Xe"
                         Style="{StaticResource NavMenuButton}" Tag="Magnify"
                         CommandParameter="BM3" Click="NavigationButton_Click"/>
            <RadioButton x:Name="Bm4Button" Content="Phiếu Thu Tiền"
                         Style="{StaticResource NavMenuButton}" Tag="Cash"
                         CommandParameter="BM4" Click="NavigationButton_Click"/>
            <RadioButton x:Name="Bm5Button" Content="Báo Cáo Tháng"
                         Style="{StaticResource NavMenuButton}" Tag="ChartBar"
                         CommandParameter="BM5" Click="NavigationButton_Click"/>
            <RadioButton x:Name="Qd6Button" Content="Thay Đổi Quy Định"
                         Style="{StaticResource NavMenuButton}" Tag="CogOutline"
                         CommandParameter="QD6" Click="NavigationButton_Click"/>

            <!-- User Info & Logout Section -->
            <Border BorderBrush="#252D3A" BorderThickness="0,1,0,0" Margin="12,20,12,0" Padding="0,20,0,0">
                <StackPanel>
                    <Grid Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" Background="#252D3A" CornerRadius="18">
                            <materialDesign:PackIcon Kind="Account" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtUserName" Text="Tên nhân viên" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                            <TextBlock x:Name="txtUserRole" Text="Vai trò" Foreground="#757681" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Đăng xuất"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#EF4444"
                            HorizontalAlignment="Left"
                            Margin="4,0,0,0"
                            Click="LogoutButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Logout" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
