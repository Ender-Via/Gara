<Window x:Class="WpfApp1.Views.QuyDinhWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="QuyDinhWindow" Height="482" Width="653">
    <Grid Margin="0,0,0,2">
        <Border Background="#FFF5F5F5"
            CornerRadius="10"
            Padding="20"
            Width="654"
            HorizontalAlignment="Center" Margin="0,0,0,10">

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="⚙️ QUY ĐỊNH HỆ THỐNG"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                <!-- Số hiệu xe -->
                <StackPanel Margin="0,5">
                    <TextBlock Text="Số lượng hiệu xe"/>
                    <TextBox x:Name="txtHieuXe" Height="30" Width="614"/>
                </StackPanel>

                <!-- Số xe tối đa -->
                <StackPanel Margin="0,5">
                    <TextBlock Text="Số xe tối đa / ngày"/>
                    <TextBox x:Name="txtSoXeToiDa" Height="30"/>
                </StackPanel>

                <!-- Vật tư -->
                <StackPanel Margin="0,5">
                    <TextBlock Text="Số loại vật tư"/>
                    <TextBox x:Name="txtVatTu" Height="30"/>
                </StackPanel>

                <!-- Tiền công -->
                <StackPanel Margin="0,5">
                    <TextBlock Text="Số loại tiền công"/>
                    <TextBox x:Name="txtTienCong" Height="30"/>
                </StackPanel>

                <!-- Button -->
                <Button x:Name="btnSave" Content="Lưu thay đổi"
                    Height="40"
                    Margin="0,20,0,0"
                    Background="#FF4CAF50"
                    Foreground="White"
                    FontWeight="Bold" Width="126" Command="{Binding SaveCommand}"/>

            </StackPanel>

        </Border>
    </Grid>
</Window>
