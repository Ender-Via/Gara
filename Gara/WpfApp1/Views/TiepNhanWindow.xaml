<Window x:Class="WpfApp1.Views.TiepNhanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Tiếp Nhận Xe Sửa" Height="350" Width="700" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="TIẾP NHẬN XE SỬA" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0 -->
            <TextBlock Text="Tên chủ xe:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtTenChuXe" Grid.Row="0" Grid.Column="1" Margin="5" Padding="4" Text="{Binding TenChuXe, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Biển số:" Grid.Row="0" Grid.Column="2" Margin="20,5,5,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtBienSo" Grid.Row="0" Grid.Column="3" Margin="5" Padding="4" Text="{Binding BienSo, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 1 -->
            <TextBlock Text="Điện thoại:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtDienThoai" Grid.Row="1" Grid.Column="1" Margin="5" Padding="4" Text="{Binding DienThoai, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Hiệu xe:" Grid.Row="1" Grid.Column="2" Margin="20,5,5,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbHieuXe" Grid.Row="1" Grid.Column="3" Margin="5" Padding="4" ItemsSource="{Binding DanhSachHieuXe}" SelectedItem="{Binding HieuXeDuocChon}"/>

            <!-- Row 2 -->
            <TextBlock Text="Địa chỉ:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtDiaChi" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="5" Padding="4" Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Row 3 -->
            <TextBlock Text="Ngày tiếp nhận:" Grid.Row="3" Grid.Column="0" Margin="5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <DatePicker x:Name="dpNgayTiepNhan" Grid.Row="3" Grid.Column="1" Margin="5" Padding="4" SelectedDate="{Binding NgayTiepNhan, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnLuu" Content="Lưu" Width="100" Height="35" Margin="10" Command="{Binding LuuCommand}"/>
            <Button x:Name="btnDong" Content="Đóng" Width="100" Height="35" Margin="10" Command="{Binding DongCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
