<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Gara - Menu" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" Background="#E5E7EB">
    
    <Window.Resources>
        <Style x:Key="ModernMenuButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel MaxWidth="350" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="MAIN MENU" FontSize="28" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button Content="1. Tiếp nhận bảo trì xe" Style="{StaticResource ModernMenuButton}" Click="BtnTiepNhan_Click"/>
            <Button Content="2. Lập phiếu sửa chữa" Style="{StaticResource ModernMenuButton}" Click="BtnSuaChua_Click"/>
            <Button Content="3. Tra cứu xe" Style="{StaticResource ModernMenuButton}" Click="BtnTraCuu_Click"/>
            <Button Content="4. Lập phiếu thu tiền" Style="{StaticResource ModernMenuButton}" Click="BtnPhieuThu_Click"/>
            <Button Content="5. Lập báo cáo tháng" Style="{StaticResource ModernMenuButton}" Click="BtnBaoCao_Click"/>
            <Button Content="6. Thay đổi qui định" Style="{StaticResource ModernMenuButton}" Click="BtnQuyDinh_Click"/>
        </StackPanel>
    </Grid>
</Window>